# VITE_OLLAMA_ENDPOINT: The local or remote URL where Ollama is running.
# Default is usually http://localhost:11434
VITE_OLLAMA_ENDPOINT="http://localhost:11434"

# VITE_OLLAMA_MODEL: The model to use for the AI Co-Pilot logic.
VITE_OLLAMA_MODEL="llama3"

# VITE_TOMTOM_API_KEY: Required for the global traffic flow overlay layer on the Leaflet map.
VITE_TOMTOM_API_KEY="YOUR_TOMTOM_KEY_HERE"
